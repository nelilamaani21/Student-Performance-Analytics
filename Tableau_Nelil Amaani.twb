      <column caption='Performance Category' datatype='string' name='[Calculation_2758181630091265]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Exam_Score] &gt;= 75 THEN &quot;High Performer&quot; ELSE &quot;Low Performer&quot; END' />
